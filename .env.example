# DNS credentials — set the keys for your chosen dns-provider (see infra-defaults.md)
# If dns-provider is "manual", no credentials are needed — skip this file entirely.
# Only fill in the section for your chosen provider.

# Namecheap (dns-provider: namecheap)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=

# Cloudflare (dns-provider: cloudflare)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
